float3 sampleImage(uint x, uint y)
{
    if (x >= IMG_W || y >= IMG_H) return float3(0,0,0);
    uint idx = y * (IMG_W / 4) + x / 4;
    uint shift = (x % 4) * 8;
    uint packed = 0;
    if (idx < 4096u) packed = g_img0[idx - 0u];
    else if (idx < 8192u) packed = g_img1[idx - 4096u];
    else if (idx < 12288u) packed = g_img2[idx - 8192u];
    else packed = g_img3[idx - 12288u];
    packed = (packed >> shift) & 0xFF;
    float r = float((packed >> 5) & 7) / 7.0;
    float g = float((packed >> 2) & 7) / 7.0;
    float b = float(packed & 3) / 3.0;
    return float3(r, g, b);
}

float luma(float3 c) { return dot(c, float3(0.299, 0.587, 0.114)); }

float hash(float2 p) { return frac(sin(dot(p, float2(127.1, 311.7))) * 43758.5453); }

float noise(float2 p)
{
    float2 i = floor(p);
    float2 f = frac(p);
    f = f * f * (3.0 - 2.0 * f);
    float a = hash(i), b = hash(i + float2(1,0));
    float c = hash(i + float2(0,1)), d = hash(i + float2(1,1));
    return lerp(lerp(a, b, f.x), lerp(c, d, f.x), f.y);
}

// Apply animated glow/ray effects to a single sub-pixel
float3 animatePixel(float3 col, float2 subUV)
{
    // Position relative to image centre, aspect-corrected
    float2 cp = (subUV - 0.5) * 2.0;
    cp.x *= 16.0 / 9.0;
    float dist = length(cp);
    float ang = atan2(cp.y, cp.x);

    float bri = luma(col);
    float green = col.g - max(col.r, col.b);

    // Glow participation: bright green areas glow most, white areas partially
    float glowAmt = smoothstep(0.06, 0.3, bri) * smoothstep(-0.02, 0.08, green);
    float whiteGlow = smoothstep(0.45, 0.85, bri) * 0.4;
    glowAmt = max(glowAmt, whiteGlow);

    // --- 1) Breathing pulse ---
    float pulse = 0.82 + 0.18 * sin(g_time * 1.0);
    col *= lerp(1.0, pulse, glowAmt);

    // --- 2) Animated light rays emanating from sphere centre ---
    // Multiple rays at different speeds/widths for organic feel
    float rayTotal = 0.0;
    float r1 = exp(-abs(sin(ang * 1.0 - g_time * 0.2)) * 5.0);
    float r2 = exp(-abs(sin(ang * 1.5 + g_time * 0.15 + 1.0)) * 7.0);
    float r3 = exp(-abs(sin(ang * 2.0 - g_time * 0.12 + 2.5)) * 6.0);
    float r4 = exp(-abs(sin(ang * 0.7 + g_time * 0.25 + 4.0)) * 4.0);
    rayTotal = r1 + r2 * 0.6 + r3 * 0.5 + r4 * 0.8;

    // Rays strongest in the glow ring zone (~0.4–0.7 from centre)
    float rayRadial = exp(-pow((dist - 0.55) * 2.5, 2.0));
    // Also extend rays outward, fading with distance
    float rayExtend = smoothstep(0.25, 0.45, dist) * exp(-(max(0.0, dist - 0.6)) * 1.5);
    float rayMask = max(rayRadial, rayExtend * 0.6);

    // Noisy ray modulation for volumetric feel
    float nz = noise(float2(ang * 3.0 + g_time * 0.3, dist * 4.0));
    rayTotal *= (0.7 + 0.3 * nz);

    float3 rayColor = float3(0.1, 0.9, 0.2); // green rays
    col += rayColor * rayTotal * rayMask * 0.25 * glowAmt;

    // --- 3) Ring intensity wave ---
    float ringDist = abs(dist - 0.48);
    float ringMask = exp(-ringDist * 12.0);
    float ringWave = 0.85 + 0.15 * sin(ang * 3.0 - g_time * 2.0);
    float ringWave2 = 0.9 + 0.1 * sin(ang * 5.0 + g_time * 1.5 + 1.0);
    col += col * ringMask * (ringWave * ringWave2 - 0.7) * 0.6;

    // --- 4) Broad glow bloom pulsation ---
    float bloomDist = smoothstep(0.8, 0.3, dist);
    float bloomPulse = 0.0 + 0.15 * sin(g_time * 0.8 + 0.5);
    col += float3(0.05, 0.3, 0.08) * bloomDist * bloomPulse * glowAmt;

    return col;
}

float4 main(float4 pixPos : SV_Position, float2 uv : TEXCOORD0) : SV_Target
{
    float2 cell = float2(160.0, 90.0);
    float2 grid = floor(uv * cell);
    float2 cellUV = frac(uv * cell);

    uint cx = uint(grid.x) * 2;
    uint cy = uint(grid.y) * 2;

    // Sample 2x2 sub-pixels and apply animation to each BEFORE block element conversion
    float2 subUV00 = (float2(cx,     cy)     + 0.5) / float2(IMG_W, IMG_H);
    float2 subUV10 = (float2(cx + 1, cy)     + 0.5) / float2(IMG_W, IMG_H);
    float2 subUV01 = (float2(cx,     cy + 1) + 0.5) / float2(IMG_W, IMG_H);
    float2 subUV11 = (float2(cx + 1, cy + 1) + 0.5) / float2(IMG_W, IMG_H);

    float3 q00 = animatePixel(sampleImage(cx,     cy),     subUV00);
    float3 q10 = animatePixel(sampleImage(cx + 1, cy),     subUV10);
    float3 q01 = animatePixel(sampleImage(cx,     cy + 1), subUV01);
    float3 q11 = animatePixel(sampleImage(cx + 1, cy + 1), subUV11);

    float l00 = luma(q00), l10 = luma(q10);
    float l01 = luma(q01), l11 = luma(q11);
    float lAvg = (l00 + l10 + l01 + l11) * 0.25;

    float thresh = lAvg;
    uint pattern = 0u;
    pattern |= (l00 > thresh) ? 8u : 0u;
    pattern |= (l10 > thresh) ? 4u : 0u;
    pattern |= (l01 > thresh) ? 2u : 0u;
    pattern |= (l11 > thresh) ? 1u : 0u;

    float3 fg = float3(0,0,0), bgC = float3(0,0,0);
    float fgN = 0.0, bgN = 0.0;
    if (l00 > thresh) { fg += q00; fgN += 1.0; } else { bgC += q00; bgN += 1.0; }
    if (l10 > thresh) { fg += q10; fgN += 1.0; } else { bgC += q10; bgN += 1.0; }
    if (l01 > thresh) { fg += q01; fgN += 1.0; } else { bgC += q01; bgN += 1.0; }
    if (l11 > thresh) { fg += q11; fgN += 1.0; } else { bgC += q11; bgN += 1.0; }
    if (fgN > 0.0) fg /= fgN;
    if (bgN > 0.0) bgC /= bgN;

    bool isL = cellUV.x < 0.5;
    bool isT = cellUV.y < 0.5;

    float mask = 0.0;
    if      (pattern == 15u) mask = 1.0;
    else if (pattern == 12u) mask = isT ? 1.0 : 0.0;
    else if (pattern ==  3u) mask = isT ? 0.0 : 1.0;
    else if (pattern == 10u) mask = isL ? 1.0 : 0.0;
    else if (pattern ==  5u) mask = isL ? 0.0 : 1.0;
    else if (pattern ==  8u) mask = (isT && isL) ? 1.0 : 0.0;
    else if (pattern ==  4u) mask = (isT && !isL) ? 1.0 : 0.0;
    else if (pattern ==  2u) mask = (!isT && isL) ? 1.0 : 0.0;
    else if (pattern ==  1u) mask = (!isT && !isL) ? 1.0 : 0.0;
    else if (pattern ==  9u) mask = ((isT && isL) || (!isT && !isL)) ? 1.0 : 0.0;
    else if (pattern ==  6u) mask = ((isT && !isL) || (!isT && isL)) ? 1.0 : 0.0;
    else if (pattern == 14u) mask = (!isT && !isL) ? 0.0 : 1.0;
    else if (pattern == 13u) mask = (!isT && isL) ? 0.0 : 1.0;
    else if (pattern == 11u) mask = (isT && !isL) ? 0.0 : 1.0;
    else if (pattern ==  7u) mask = (isT && isL) ? 0.0 : 1.0;

    float3 color = lerp(bgC, fg, mask);

    // Thin grid lines between cells
    float2 edgeDist = min(cellUV, 1.0 - cellUV);
    float gridLine = smoothstep(0.0, 0.06, edgeDist.x) * smoothstep(0.0, 0.06, edgeDist.y);
    color *= gridLine;

    // Subtle scanlines
    float scanline = 0.97 + 0.03 * sin(uv.y * 90.0 * 6.2832);
    color *= scanline;

    // Vignette
    float2 vc = uv - 0.5;
    color *= 1.0 - dot(vc, vc) * 0.6;

    return float4(max(color, 0.0), 1.0);
}
