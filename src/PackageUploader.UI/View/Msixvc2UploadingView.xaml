<?xml version="1.0" encoding="utf-8" ?>
<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="PackageUploader.UI.View.Msixvc2UploadingView"
             xmlns:viewmodel="clr-namespace:PackageUploader.UI.ViewModel"
             xmlns:converters="clr-namespace:PackageUploader.UI.Converters"
             xmlns:strings="clr-namespace:PackageUploader.UI.Resources.Strings"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodel:Msixvc2UploadingViewModel}"
             Background="{DynamicResource AppBackgroundBrush}">
    <UserControl.Resources>
        <converters:Msixvc2UploadStageToVisibilityConverter x:Key="Msixvc2StageConverter" />
        <Storyboard x:Key="RotateAnimation">
            <DoubleAnimation
                Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                From="0"
                To="360"
                Duration="0:0:5"
                RepeatBehavior="Forever" />
        </Storyboard>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <!-- Icon -->
            <RowDefinition Height="Auto"/>
            <!-- Title -->
            <RowDefinition Height="Auto"/>
            <!-- Progress bar -->
            <RowDefinition Height="Auto"/>
            <!-- Upload stats -->
            <RowDefinition Height="Auto"/>
            <!-- Stage checkpoints -->
            <RowDefinition Height="Auto"/>
            <!-- Cancel button -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Hero icon -->
        <Image Grid.Row="0"
               Margin="{DynamicResource ProgressImageMargin}"
               Source="/Resources/Images/InProgress.png"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Height="{DynamicResource StatusImageSize}"
               Width="{DynamicResource StatusImageSize}" />

        <!-- Title -->
        <TextBlock Grid.Row="1"
                   Margin="{DynamicResource ProgressHeadingMargin}"
                   Style="{StaticResource SubHeadline}"
                   Text="{x:Static strings:Msixvc2Uploading.TitleText}"
                   d:Text="Uploading package to Partner Center"
                   Foreground="{DynamicResource PrimaryTextBrush}" />

        <!-- Progress bar -->
        <Grid Grid.Row="2"
              Margin="{DynamicResource ProgressSectionMargin}"
              MaxWidth="{DynamicResource ProgressBarMaxWidth}"
              HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Margin="0, 0, 0, 10"
                       Text="{x:Static strings:Msixvc2Uploading.UploadingText}"
                       d:Text="Uploading"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       HorizontalAlignment="Left"/>
            <StackPanel Grid.Row="0"
                        Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="12,0,0,10">
                <TextBlock Text="{Binding UploadPercentage, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Text="{x:Static strings:Msixvc2Uploading.PercentCompleteText}"
                           d:Text="% complete"
                           Foreground="{DynamicResource PrimaryTextBrush}" />
            </StackPanel>
            <ProgressBar Grid.Row="1"
                         Grid.ColumnSpan="2"
                         Minimum="0"
                         Maximum="100"
                         Value="{Binding UploadPercentage}"
                         Visibility="Visible"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch"
                         Height="3"/>
        </Grid>

        <!-- Upload stats (visible only during Uploading stage) -->
        <TextBlock Grid.Row="3"
                   HorizontalAlignment="Center"
                   Text="{Binding UploadStats}"
                   Foreground="{DynamicResource SecondaryTextBrush}"
                   Visibility="{Binding ShowUploadStats, Converter={StaticResource BooleanToVisibilityConverter}}"
                   FontSize="{DynamicResource SmallFontSize}"/>

        <!-- Stage checkpoints -->
        <Grid Grid.Row="4" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="28" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <!-- Row 0: Preparing -->
            <!-- Spinning gear when Preparing is active -->
            <Image Grid.Row="0" Grid.Column="0"
                   Source="/Resources/AppIcon/Settings.png"
                   Visibility="{Binding UploadStage, Converter={StaticResource Msixvc2StageConverter}, ConverterParameter=Preparing}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Height="16" Width="16">
                <Image.RenderTransform>
                    <RotateTransform CenterX="8" CenterY="8" />
                </Image.RenderTransform>
                <Image.Triggers>
                    <EventTrigger RoutedEvent="Image.Loaded">
                        <BeginStoryboard Storyboard="{StaticResource RotateAnimation}" />
                    </EventTrigger>
                </Image.Triggers>
            </Image>
            <!-- Green check when past Preparing -->
            <Image Grid.Row="0" Grid.Column="0"
                   Source="/Resources/AppIcon/Accept.png"
                   Visibility="{Binding UploadStage, Converter={StaticResource Msixvc2StageConverter}, ConverterParameter=Uploading-Done}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Height="16" Width="16" />
            <TextBlock Grid.Row="0" Grid.Column="1"
                       Text="{x:Static strings:Msixvc2Uploading.PreparingText}"
                       d:Text="Preparing package..."
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       HorizontalAlignment="Left" VerticalAlignment="Center"/>

            <!-- Row 1: Uploading -->
            <!-- Grey clock when not yet reached -->
            <ContentControl Grid.Row="1" Grid.Column="0"
                            Template="{StaticResource ClockFaceWaitingTemplate}"
                            Visibility="{Binding UploadStage, Converter={StaticResource Msixvc2StageConverter}, ConverterParameter=Preparing}"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Height="16" Width="16" />
            <!-- Spinning gear when Uploading is active -->
            <Image Grid.Row="1" Grid.Column="0"
                   Source="/Resources/AppIcon/Settings.png"
                   Visibility="{Binding UploadStage, Converter={StaticResource Msixvc2StageConverter}, ConverterParameter=Uploading}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Height="16" Width="16">
                <Image.RenderTransform>
                    <RotateTransform CenterX="8" CenterY="8" />
                </Image.RenderTransform>
                <Image.Triggers>
                    <EventTrigger RoutedEvent="Image.Loaded">
                        <BeginStoryboard Storyboard="{StaticResource RotateAnimation}" />
                    </EventTrigger>
                </Image.Triggers>
            </Image>
            <!-- Green check when past Uploading -->
            <Image Grid.Row="1" Grid.Column="0"
                   Source="/Resources/AppIcon/Accept.png"
                   Visibility="{Binding UploadStage, Converter={StaticResource Msixvc2StageConverter}, ConverterParameter=Validating-Done}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Height="16" Width="16" />
            <TextBlock Grid.Row="1" Grid.Column="1"
                       Text="{x:Static strings:Msixvc2Uploading.UploadingContentText}"
                       d:Text="Uploading content..."
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       HorizontalAlignment="Left" VerticalAlignment="Center"/>

            <!-- Row 2: Validating -->
            <!-- Grey clock when not yet reached -->
            <ContentControl Grid.Row="2" Grid.Column="0"
                            Template="{StaticResource ClockFaceWaitingTemplate}"
                            Visibility="{Binding UploadStage, Converter={StaticResource Msixvc2StageConverter}, ConverterParameter=Preparing-Uploading}"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Height="16" Width="16" />
            <!-- Spinning gear when Validating is active -->
            <Image Grid.Row="2" Grid.Column="0"
                   Source="/Resources/AppIcon/Settings.png"
                   Visibility="{Binding UploadStage, Converter={StaticResource Msixvc2StageConverter}, ConverterParameter=Validating}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Height="16" Width="16">
                <Image.RenderTransform>
                    <RotateTransform CenterX="8" CenterY="8" />
                </Image.RenderTransform>
                <Image.Triggers>
                    <EventTrigger RoutedEvent="Image.Loaded">
                        <BeginStoryboard Storyboard="{StaticResource RotateAnimation}" />
                    </EventTrigger>
                </Image.Triggers>
            </Image>
            <!-- Green check when past Validating -->
            <Image Grid.Row="2" Grid.Column="0"
                   Source="/Resources/AppIcon/Accept.png"
                   Visibility="{Binding UploadStage, Converter={StaticResource Msixvc2StageConverter}, ConverterParameter=Finalizing-Done}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Height="16" Width="16" />
            <TextBlock Grid.Row="2" Grid.Column="1"
                       Text="{x:Static strings:Msixvc2Uploading.ValidatingText}"
                       d:Text="Validating package..."
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       HorizontalAlignment="Left" VerticalAlignment="Center"/>

            <!-- Row 3: Finalizing -->
            <!-- Grey clock when not yet reached -->
            <ContentControl Grid.Row="3" Grid.Column="0"
                            Template="{StaticResource ClockFaceWaitingTemplate}"
                            Visibility="{Binding UploadStage, Converter={StaticResource Msixvc2StageConverter}, ConverterParameter=Preparing-Validating}"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Height="16" Width="16" />
            <!-- Spinning gear when Finalizing is active -->
            <Image Grid.Row="3" Grid.Column="0"
                   Source="/Resources/AppIcon/Settings.png"
                   Visibility="{Binding UploadStage, Converter={StaticResource Msixvc2StageConverter}, ConverterParameter=Finalizing}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Height="16" Width="16">
                <Image.RenderTransform>
                    <RotateTransform CenterX="8" CenterY="8" />
                </Image.RenderTransform>
                <Image.Triggers>
                    <EventTrigger RoutedEvent="Image.Loaded">
                        <BeginStoryboard Storyboard="{StaticResource RotateAnimation}" />
                    </EventTrigger>
                </Image.Triggers>
            </Image>
            <!-- Green check when Done -->
            <Image Grid.Row="3" Grid.Column="0"
                   Source="/Resources/AppIcon/Accept.png"
                   Visibility="{Binding UploadStage, Converter={StaticResource Msixvc2StageConverter}, ConverterParameter=Done}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Height="16" Width="16" />
            <TextBlock Grid.Row="3" Grid.Column="1"
                       Text="{x:Static strings:Msixvc2Uploading.FinalizingText}"
                       d:Text="Finalizing upload..."
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       HorizontalAlignment="Left" VerticalAlignment="Center"/>
        </Grid>

        <!-- Cancel button -->
        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="{x:Static strings:Msixvc2Uploading.CancelUploadButtonText}"
                    d:Content="Cancel upload"
                    Command="{Binding CancelUploadCommand}"
                    IsEnabled="True"
                    Margin="0, 0, 50, 50"
                    Width="150"
                    Height="30"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"/>
        </StackPanel>
    </Grid>
</UserControl>
