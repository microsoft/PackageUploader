<?xml version="1.0" encoding="utf-8" ?>
<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodel="clr-namespace:PackageUploader.UI.ViewModel"
             xmlns:strings="clr-namespace:PackageUploader.UI.Resources.Strings"
             x:Class="PackageUploader.UI.View.Msixvc2UploadView"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodel:Msixvc2UploadViewModel}">
    <UserControl.Resources>
        <Storyboard x:Key="RotateAnimation">
            <DoubleAnimation
            Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
            From="0"
            To="360"
            Duration="0:0:5"
            RepeatBehavior="Forever" />
        </Storyboard>
    </UserControl.Resources>
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <StackPanel Margin="32">
            <!-- Back Arrow -->
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Top"
                        Margin="0, 0, 0, 15">
                <Button Width="16"
                        Height="16"
                        Command="{Binding CancelButtonCommand}"
                        Style="{StaticResource WindowControlButtonStyle}"
                        AutomationProperties.HelpText="Back to home">
                    <Path Data="M16,8 L4,8 M4,8 L8,4 M4,8 L8,12" 
                          Stroke="{DynamicResource PrimaryTextBrush}" 
                          StrokeThickness="1.5" 
                          Stretch="None" 
                          VerticalAlignment="Center" 
                          HorizontalAlignment="Center"/>
                </Button>
            </StackPanel>

            <!-- Title -->
            <TextBlock Text="{x:Static strings:Msixvc2Upload.TitleText}"
                       d:Text="Upload Loose Files (PC only)"
                       Style="{StaticResource Headline}"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       HorizontalAlignment="Left"/>
            <TextBlock Text="{x:Static strings:Msixvc2Upload.SubtitleText}"
                       d:Text="Point to your loose file directory for your PC game containing a MicrosoftGame.config and we will package and upload using the MSIXVC2 format."
                       HorizontalAlignment="Left"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       TextWrapping="Wrap"
                       Margin="0,5,0,20"/>

            <!-- Main Grid: 4 columns, 2 rows -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="607"/>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="468" />
                </Grid.ColumnDefinitions>

                <!-- ============================================ -->
                <!-- Step 1 — Build location                      -->
                <!-- ============================================ -->
                <StackPanel Grid.Row="0"
                            Grid.Column="0"
                            Orientation="Horizontal">
                    <Border Width="24"
                            Height="24"
                            CornerRadius="12"
                            VerticalAlignment="Top"
                            Padding="2"
                            BorderBrush="{DynamicResource LightPurplishBlueBrush}"
                            BorderThickness="1">
                        <TextBlock Text="1" Foreground="{DynamicResource LightPurplishBlueBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Row="0"
                            Grid.Column="1"
                            Orientation="Vertical">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="476"/>
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="96"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{x:Static strings:Msixvc2Upload.BuildLocationTitle}"
                                   d:Text="Build location"
                                   Style="{StaticResource SubHeadline}"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   HorizontalAlignment="Left"
                                   Margin="0,0,0,5"/>
                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                                   Text="{x:Static strings:Msixvc2Upload.BuildLocationText}"
                                   d:Text="Locate your loose file directory containing a MicrosoftGame.config. Add a layout file under Additional Details."
                                   HorizontalAlignment="Left"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="{x:Static strings:Msixvc2Upload.ContentPathTitleText}"
                                   d:Text="Content path"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   HorizontalAlignment="Left"
                                   Margin="0,0,0,5"/>
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="{x:Static strings:Msixvc2Upload.RequiredText}"
                                   d:Text="Required"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   HorizontalAlignment="Right"
                                   Margin="0,0,0,5"/>
                        <TextBox Grid.Row="3" Grid.Column="0"
                                 x:Name="ContentPathTextBox"
                                 AutomationProperties.HelpText="Path to content directory"
                                 Text="{Binding ContentPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 Background="{DynamicResource SecondaryButtonBrush}"
                                 Margin="0,0,0,10">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border x:Name="Border"
                                                        Background="{TemplateBinding Background}" 
                                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6">
                                                    <Grid>
                                                        <TextBlock Text="{x:Static strings:Msixvc2Upload.ContentPathBoxDefaultText}"
                                                                   d:Text="Select or enter the content directory" 
                                                                   Foreground="{DynamicResource SecondaryTextBrush}" 
                                                                   VerticalAlignment="Center"
                                                                   Visibility="{Binding Text.IsEmpty, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BooleanToVisibilityConverter}}" 
                                                                   Margin="15,2"/>
                                                        <ScrollViewer x:Name="PART_ContentHost" 
                                                                      Margin="5,2" 
                                                                      VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource TextEntryHighlightedBackgroundBrush}" />
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding ContentPathError, Converter={StaticResource StringNotEmptyToVisibilityConverter}}" Value="Visible">
                                                        <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource ErrorRedBrush}" />
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <Button Grid.Row="3" Grid.Column="2"
                                Content="{x:Static strings:Msixvc2Upload.BrowseText}"
                                d:Content="Browse"
                                AutomationProperties.HelpText="{x:Static strings:Msixvc2Upload.BrowseContentPathHelpText}"
                                Command="{Binding BrowseContentPathCommand}"
                                IsEnabled="True"
                                Width="90"
                                Height="32"
                                Margin="0,0,0,10"/>
                        <StackPanel Grid.Row="4" Grid.Column="0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Left"
                                    Visibility="{Binding ContentPathError, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                            <Image Source="/Resources/AppIcon/ErrorIcon.png"
                                   Width="16" Height="16"
                                   VerticalAlignment="Top"
                                   Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding ContentPathError}"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       HorizontalAlignment="Left"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <!-- Additional Details Expander -->
                    <Expander Style="{StaticResource CustomExpanderStyle}"
                              Margin="0,10,0,20"
                              IsExpanded="{Binding IsAdditionalDetailsExpanded, Mode=TwoWay}">
                        <Expander.Header>
                            <TextBlock Text="{x:Static strings:Msixvc2Upload.AdditionalDetailsTitle}"
                                       d:Text="Additional details"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                        </Expander.Header>
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="476"/>
                                <ColumnDefinition Width="96" />
                            </Grid.ColumnDefinitions>

                            <!-- Layout file/content map -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="{x:Static strings:Msixvc2Upload.LayoutFileMapTitle}"
                                       d:Text="Layout file/content map"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       HorizontalAlignment="Left"
                                       Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="{x:Static strings:Msixvc2Upload.OptionalText}"
                                       d:Text="Optional"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,10,5"/>
                            <TextBox Grid.Row="1" Grid.Column="0"
                                     x:Name="MappingDataTextBox"
                                     AutomationProperties.HelpText="Path to layout file"
                                     Text="{Binding MappingDataXmlPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     Background="{DynamicResource SecondaryButtonBrush}"
                                     Margin="0,0,10,10">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border x:Name="Border"
                                                            Background="{TemplateBinding Background}" 
                                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="6">
                                                        <Grid>
                                                            <TextBlock Text="{x:Static strings:Msixvc2Upload.ContentMapPathBoxDefaultText}"
                                                                       d:Text="Select or enter the content map location" 
                                                                       Foreground="{DynamicResource SecondaryTextBrush}" 
                                                                       VerticalAlignment="Center"
                                                                       Visibility="{Binding Text.IsEmpty, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BooleanToVisibilityConverter}}" 
                                                                       Margin="15,2"/>
                                                            <ScrollViewer x:Name="PART_ContentHost" 
                                                                          Margin="5,2" 
                                                                          VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsFocused" Value="True">
                                                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource TextEntryHighlightedBackgroundBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <Button Grid.Row="1" Grid.Column="1"
                                    Content="{x:Static strings:Msixvc2Upload.BrowseText}"
                                    d:Content="Browse"
                                    AutomationProperties.HelpText="Browse to layout file"
                                    Command="{Binding BrowseMappingDataXmlPathCommand}"
                                    IsEnabled="True"
                                    Width="90"
                                    Height="32"
                                    Margin="0,0,0,10"/>
                        </Grid>
                    </Expander>
                </StackPanel>

                <!-- ============================================ -->
                <!-- Step 2 — Destination                         -->
                <!-- ============================================ -->
                <StackPanel Grid.Row="1"
                            Grid.Column="0"
                            Orientation="Horizontal">
                    <Border Width="24"
                            Height="24"
                            CornerRadius="12"
                            VerticalAlignment="Top"
                            Padding="2"
                            BorderBrush="{DynamicResource LightPurplishBlueBrush}"
                            BorderThickness="1">
                        <TextBlock Text="2" Foreground="{DynamicResource LightPurplishBlueBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Row="1"
                            Grid.Column="1"
                            Orientation="Vertical">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="476"/>
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="96"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{x:Static strings:Msixvc2Upload.DestinationTitleText}"
                                   d:Text="Destination"
                                   Style="{StaticResource SubHeadline}"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   HorizontalAlignment="Left"
                                   Margin="0,0,0,5"/>
                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                                   Text="{x:Static strings:Msixvc2Upload.DestinationSubtitleText}"
                                   d:Text="Select a destination and market for the package upload."
                                   HorizontalAlignment="Left"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>
                        <!-- Destination combo -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="{x:Static strings:Msixvc2Upload.DestinationTitleText}"
                                   d:Text="Destination"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   HorizontalAlignment="Left"
                                   Margin="0,0,0,5"/>
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="{x:Static strings:Msixvc2Upload.RequiredText}"
                                   d:Text="Required"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   HorizontalAlignment="Right"
                                   Margin="0,0,0,5"/>
                        <ComboBox Grid.Row="3" Grid.Column="0"
                                  AutomationProperties.Name="Destination"
                                  AutomationProperties.HelpText="Choose branch or flight"
                                  x:Name="flightName"
                                  ItemsSource="{Binding BranchAndFlightNames, Mode=OneWay}"
                                  SelectedItem="{Binding BranchOrFlightDisplayName, Mode=TwoWay}"
                                  IsEnabled="{Binding IsLoadingBranchesAndFlights, Converter={StaticResource InverseBooleanConverter}}"
                                  Style="{StaticResource CustomComboBoxStyle}"
                                  IsTabStop="True"
                                  TabIndex="1" />
                        <Border Grid.Row="3" Grid.Column="0"
                                BorderBrush="{DynamicResource ErrorRedBrush}"
                                CornerRadius="6"
                                BorderThickness="1"
                                Visibility="{Binding BranchOrFlightErrorMessage, Converter={StaticResource StringNotEmptyToVisibilityConverter}}" />
                        <StackPanel Grid.Row="3" Grid.Column="2"
                                    HorizontalAlignment="Left"
                                    Width="16" Height="16">
                            <Image Source="/Resources/AppIcon/Settings.png"
                                   Visibility="{Binding IsLoadingBranchesAndFlights, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Image.RenderTransform>
                                    <RotateTransform CenterX="8" CenterY="8" />
                                </Image.RenderTransform>
                                <Image.Triggers>
                                    <EventTrigger RoutedEvent="Image.Loaded">
                                        <BeginStoryboard Storyboard="{StaticResource RotateAnimation}" />
                                    </EventTrigger>
                                </Image.Triggers>
                            </Image>
                        </StackPanel>
                        <StackPanel Grid.Row="4" Grid.Column="0"
                                    Margin="0, 5, 0, 0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Left"
                                    Visibility="{Binding BranchOrFlightErrorMessage, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                            <Image Source="/Resources/AppIcon/ErrorIcon.png"
                                   Width="16" Height="16"
                                   VerticalAlignment="Top"
                                   Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding BranchOrFlightErrorMessage}"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Width="450"
                                       HorizontalAlignment="Left"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <!-- Market combo -->
                        <TextBlock Grid.Row="5" Grid.Column="0"
                                   Text="{x:Static strings:Msixvc2Upload.MarketTitleText}"
                                   d:Text="Market"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   HorizontalAlignment="Left"
                                   Margin="0,10,0,5"/>
                        <TextBlock Grid.Row="5" Grid.Column="0"
                                   Text="{x:Static strings:Msixvc2Upload.RequiredText}"
                                   d:Text="Required"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   HorizontalAlignment="Right"
                                   Margin="0,10,0,5"/>
                        <ComboBox Grid.Row="6" Grid.Column="0"
                                  x:Name="marketName"
                                  AutomationProperties.Name="Market"
                                  AutomationProperties.HelpText="Choose market"
                                  ItemsSource="{Binding MarketGroupNames, Mode=OneWay}"
                                  SelectedItem="{Binding MarketGroupName, Mode=TwoWay}"
                                  Style="{StaticResource CustomComboBoxStyle}"
                                  IsTabStop="True"
                                  TabIndex="2">
                            <ComboBox.IsEnabled>
                                <MultiBinding Converter="{StaticResource BooleanAndConverter}">
                                    <Binding Path="IsLoadingMarkets" Converter="{StaticResource InverseBooleanConverter}"/>
                                    <Binding Path="IsLoadingBranchesAndFlights" Converter="{StaticResource InverseBooleanConverter}"/>
                                </MultiBinding>
                            </ComboBox.IsEnabled>
                        </ComboBox>
                        <Border Grid.Row="6" Grid.Column="0"
                                BorderBrush="{DynamicResource ErrorRedBrush}"
                                CornerRadius="6"
                                BorderThickness="1"
                                Visibility="{Binding MarketGroupErrorMessage, Converter={StaticResource StringNotEmptyToVisibilityConverter}}" />
                        <StackPanel Grid.Row="6" Grid.Column="2"
                                    HorizontalAlignment="Left"
                                    Width="16" Height="16">
                            <Image Source="/Resources/AppIcon/Settings.png"
                                   Visibility="{Binding IsLoadingMarkets, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Image.RenderTransform>
                                    <RotateTransform CenterX="8" CenterY="8" />
                                </Image.RenderTransform>
                                <Image.Triggers>
                                    <EventTrigger RoutedEvent="Image.Loaded">
                                        <BeginStoryboard Storyboard="{StaticResource RotateAnimation}" />
                                    </EventTrigger>
                                </Image.Triggers>
                            </Image>
                        </StackPanel>
                        <StackPanel Grid.Row="7" Grid.Column="0"
                                    Margin="0, 5, 0, 0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Left"
                                    Visibility="{Binding MarketGroupErrorMessage, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                            <Image Source="/Resources/AppIcon/ErrorIcon.png"
                                   Width="16" Height="16"
                                   VerticalAlignment="Top"
                                   Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding MarketGroupErrorMessage}"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Width="450"
                                       HorizontalAlignment="Left"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- ============================================ -->
                <!-- Vertical divider                             -->
                <!-- ============================================ -->
                <Rectangle Grid.Column="2" Grid.RowSpan="2" Width="1" Fill="{DynamicResource BorderBrush}" Margin="10,0" />

                <!-- ============================================ -->
                <!-- Upload Preview (right panel)                 -->
                <!-- ============================================ -->
                <StackPanel Grid.Column="3" Grid.Row="0" Grid.RowSpan="2" Margin="10,0,0,0">
                    <TextBlock Text="{x:Static strings:Msixvc2Upload.UploadPreviewTitleText}"
                               d:Text="Upload Preview"
                               Style="{StaticResource SubHeadline}"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               HorizontalAlignment="Left"
                               Margin="0,0,0,10"/>
                    <Border BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="6"
                            Margin="0, 20, 0, 0"
                            Visibility="{Binding ProductName, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Image Grid.Row="0"
                                   Grid.Column="0"
                                   Grid.RowSpan="4"
                                   Source="{Binding PackagePreviewImage}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Height="65"
                                   Width="65"
                                   Margin="0,0,10,0"/>
                            <!-- Product name -->
                            <StackPanel Grid.Row="0"
                                        Grid.Column="1"
                                        Orientation="Vertical"
                                        HorizontalAlignment="Left"
                                        Margin="0, 0, 0, 10">
                                <TextBlock Text="{x:Static strings:Msixvc2Upload.ProductNameText}"
                                           d:Text="Product name"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <TextBlock Text="{Binding ProductName}"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                            </StackPanel>
                            <!-- Destination + Market -->
                            <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50*" />
                                    <ColumnDefinition Width="50*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Left">
                                    <TextBlock Text="{x:Static strings:Msixvc2Upload.DestinationTitleText}"
                                               d:Text="Destination"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Text="{Binding BranchOrFlightDisplayName}" 
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Left">
                                    <TextBlock Text="{x:Static strings:Msixvc2Upload.MarketTitleText}"
                                               d:Text="Market"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Text="{Binding MarketGroupName}" 
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                                </StackPanel>
                            </Grid>
                            <!-- Package Identity name -->
                            <StackPanel Grid.Row="2"
                                        Grid.Column="1"
                                        Orientation="Vertical" 
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,10">
                                <TextBlock Text="{x:Static strings:Msixvc2Upload.PackageIdentityNameTitleText}"
                                           d:Text="Package Identity name"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <TextBlock Text="{Binding PackageIdentityName}"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <!-- Store ID, Folder size, Family -->
                            <Grid Grid.Row="3" Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="33*" />
                                    <ColumnDefinition Width="33*" />
                                    <ColumnDefinition Width="33*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Left">
                                    <TextBlock Text="{x:Static strings:Msixvc2Upload.StoreIdTitleText}"
                                               d:Text="Store ID"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Text="{Binding BigId}" 
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Left">
                                    <TextBlock Text="{x:Static strings:Msixvc2Upload.FolderSizeTitleText}"
                                               d:Text="Folder size"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Text="{Binding EstimatedFolderSize}" 
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Vertical" HorizontalAlignment="Left">
                                    <TextBlock Text="{x:Static strings:Msixvc2Upload.FamilyTitleText}"
                                               d:Text="Family"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Text="{Binding PackageType}" 
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ============================================ -->
            <!-- Button panel                                 -->
            <!-- ============================================ -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button d:Content="Cancel"
                        Content="{x:Static strings:Msixvc2Upload.CancelContentText}"
                        Command="{Binding CancelButtonCommand}"
                        Width="90"
                        Height="32"
                        Margin="0,0,10,0"
                        AutomationProperties.Name="Cancel Button"
                        AutomationProperties.HelpText="{x:Static strings:Msixvc2Upload.CancelButtonHelpText}"
                        TabIndex="3" />
                <Button d:Content="Upload Package"
                        Content="{x:Static strings:Msixvc2Upload.UploadButtonContentText}"
                        Command="{Binding UploadPackageCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="133"
                        Height="34"
                        AutomationProperties.Name="Upload Package Button"
                        AutomationProperties.HelpText="{x:Static strings:Msixvc2Upload.UploadButtonHelpText}"
                        TabIndex="4" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
