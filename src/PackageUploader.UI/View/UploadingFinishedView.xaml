<UserControl x:Class="PackageUploader.UI.View.UploadingFinishedView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PackageUploader.UI.View"
             xmlns:viewmodel="clr-namespace:PackageUploader.UI.ViewModel"
             xmlns:converters="clr-namespace:PackageUploader.UI.Converters"
             xmlns:strings="clr-namespace:PackageUploader.UI.Resources.Strings"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodel:UploadingFinishedViewModel}"
             Background="{DynamicResource AppBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <!-- check -->
            <RowDefinition Height="auto"/>
            <!-- title -->
            <RowDefinition Height="auto"/>
            <!-- Main Box -->
            <RowDefinition />
            <!-- buttons row -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Image Grid.Row="0"
               Margin="0, 175, 0, 30"
               Source="/Resources/Images/Complete.png"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Height="130"
               Width="130" />
        <TextBlock Grid.Row="1"
           Margin="0, 0, 0, 23"
           Style="{StaticResource SubHeadline}"
           Text="{x:Static strings:UploadingFinished.UploadCompleteTitleText}"
           d:Text="Upload complete"
           Foreground="{DynamicResource PrimaryTextBrush}" />
        <Border Grid.Row="2"
                Margin="100, 0, 100, 0"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Package Image -->
                <Image Grid.Column="0"
                       Source="{Binding PackagePreviewImage}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Height="65" Width="65"
                       Margin="0,0,15,0"/>

                <!-- 3x3 Metadata Grid -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Row 0 -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                        <TextBlock Text="{x:Static strings:UploadingFinished.ProductNameTitleText}"
                                   d:Text="Product name"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="{Binding ProductName}"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                        <TextBlock Text="{x:Static strings:UploadingFinished.PackageIdentityNameTitleText}"
                                   d:Text="Package Identity name"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="{Binding PackageIdentityName}"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,10">
                        <TextBlock Text="{x:Static strings:UploadingFinished.StoreIdTitleText}"
                                   d:Text="Store ID"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="{Binding StoreId}"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </StackPanel>

                    <!-- Row 1 -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
                        <TextBlock Text="{x:Static strings:UploadingFinished.DestinationTitleText}"
                                   d:Text="Destination"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="{Binding Destination}"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                        <TextBlock Text="{x:Static strings:UploadingFinished.MarketTitleText}"
                                   d:Text="Market"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="{Binding Market}"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,10">
                        <TextBlock Text="{x:Static strings:UploadingFinished.FamilyTitleText}"
                                   d:Text="Family"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="{Binding PackageType}"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </StackPanel>

                    <!-- Row 2 -->
                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Text="{x:Static strings:UploadingFinished.FolderSizeTitleText}"
                                   d:Text="Folder size"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="{Binding FolderSize}"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="1"
                                Visibility="{Binding HasUploadSize, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{x:Static strings:UploadingFinished.UploadSizeTitleText}"
                                   d:Text="Upload Size"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="{Binding UploadSize}"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </StackPanel>
                </Grid>

                <!-- View in Partner Center Button -->
                <Button Grid.Column="2"
                        Content="{x:Static strings:UploadingFinished.ViewPartnerCenterButtonContent}"
                        d:Content="View in Partner Center"
                        Command="{Binding ViewInPartnerCenterCommand}"
                        IsEnabled="True"
                        Width="150" Height="30"
                        VerticalAlignment="Center"
                        Margin="10,0,0,0"/>
            </Grid>
        </Border>
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom">
            <Button Content="{x:Static strings:UploadingFinished.ViewLogsButtonContent}"
                    d:Content="View logs"
                    Command="{Binding ViewLogsCommand}"
                    Style="{StaticResource HyperlinkButtonStyle}"
                    Margin="0, 0, 20, 20" />
            <Button Content="{x:Static strings:UploadingFinished.GoHomeButtonContent}"
                    d:Content="Go Home"
                    Command="{Binding HomeCommand}"
                    IsEnabled="True"
                    Margin="0, 0, 20, 20"
                    Width="150"
                    Height="30"/>
        </StackPanel>
    </Grid>
</UserControl>
