<?xml version="1.0" encoding="utf-8"?>
<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PackageUploader.UI.View.StubConfigDialog"
        Title="{Binding Title, RelativeSource={RelativeSource Self}}"
        Height="260"
        Width="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Platform selection -->
        <TextBlock Grid.Row="0" Grid.Column="0"
                   x:Name="PlatformLabel"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   Margin="0,0,12,12" />
        <ComboBox x:Name="PlatformCombo" Grid.Row="0" Grid.Column="1"
                  Margin="0,0,0,12" Height="24" VerticalContentAlignment="Center"
                  SelectionChanged="PlatformCombo_SelectionChanged">
            <ComboBoxItem Content="PC" Tag="PC" />
            <ComboBoxItem Content="Xbox Series X|S (Scarlett)" Tag="Scarlett" />
            <ComboBoxItem Content="Xbox One" Tag="XboxOne" />
        </ComboBox>

        <!-- GDK Version selection -->
        <TextBlock Grid.Row="1" Grid.Column="0"
                   x:Name="GdkVersionLabel"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   Margin="0,0,12,12" />
        <ComboBox x:Name="GdkVersionCombo" Grid.Row="1" Grid.Column="1"
                  Margin="0,0,0,12" Height="24" VerticalContentAlignment="Center" />

        <!-- MSBuild status -->
        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                   x:Name="MsBuildStatusText"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   Margin="0,0,0,8" />

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="BuildButton"
                    Width="80"
                    Margin="0,0,10,0"
                    Click="BuildButton_Click" />
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Width="80"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
